# Mode
MODE=test

# Database
DATABASE_CONNECTION_STRING=postgresql://local_user:local_password@localhost:5432/local_db
DATABASE_NAME=local_db
DATABASE_SERVER_VERSION=17.5

# Encryption
ENCRYPTION_TEXT_32_BYTES=a7G1NRm7RAHFHECqEdEHX5Yu5xJKZ2FakvTYPiUAgv0=
ENCRYPTION_TEXT_16_BYTES=aCL9qUdHmKeyhJaARanb8Q==

# Google OAuth
GOOGLE_REDIRECT_URI=https://localhost:3000/api/v1/google/redirect
GOOGLE_LOGIN_URI=https://localhost:3000/api/v1/google/login
GOOGLE_WEB_REDIRECT_URI=http://localhost:3000/api/v1/web/auth/redirect
GOOGLE_WEB_LOGIN_URI=http://localhost:3000/chat
GOOGLE_SERVICE_ACCOUNT_ID=ServiceAccountId
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=ServiceAccountPrivateKey
GOOGLE_SPEECH_PROJECT_ID=SpeechProjectId
GOOGLE_SPEECH_REGION=us
GOOGLE_SPEECH_RECOGNIZER_ID=SpeechRecognizerId
GOOGLE_SPEECH_MODEL=chirp_3
GOOGLE_SPEECH_LANGUAGE_CODES=pt-BR,en-US
GOOGLE_SPEECH_ENDPOINT=us-speech.googleapis.com
GOOGLE_APPLICATION_NAME=TheChatbot
GOOGLE_SHEETS_TEST_SHEET_ID=TestSheetId

# WhatsApp Business
WHATSAPP_VERSION=v21.0

# AI Provider
AI_PROVIDER=openai

# OpenAI (for speech-to-text)
OPENAI_SPEECH_MODEL=whisper-1

# Web Chat Auth
JWT_SECRET=test-jwt-secret
JWT_EXPIRES_IN=7d
