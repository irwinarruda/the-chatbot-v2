{
  "name": "the-chatbot-v2",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "dev:ngrok": "ngrok http --url=parrot-fun-nicely.ngrok-free.app --region us 3000",
    "dev:local": "MODE=development bun run services:ready && MODE=development bun infra/scripts/seed-allowed-entries.ts && concurrently -n vite,ngrok -c red,blue -k \"bun run dev\" \"bun run dev:ngrok\"",
    "dev:debug": "NODE_OPTIONS='--inspect=localhost:9230/the-chatbot-v2' vite dev",
    "dev:local:debug": "MODE=development bun run services:ready && MODE=development bun infra/scripts/seed-allowed-entries.ts && concurrently -n vite,ngrok -c red,blue -k \"bun run dev:debug\" \"bun run dev:ngrok\"",
    "build:local": "vite build --mode development && vite preview --mode development",
    "build": "vite build",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "MODE=test bun run services:ready && vitest run",
    "test:coverage": "MODE=test bun run services:ready && vitest run --coverage",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:watch": "vitest",
    "test:dev": "vitest run --mode development",
    "test:prev": "vitest run --mode preview",
    "migrate:up": "bun infra/scripts/migrate.ts up",
    "migrate:down": "bun infra/scripts/migrate.ts down",
    "migrate:create": "node-pg-migrate create --migration-file-language js --migrations-dir infra/migrations",
    "migrate:production:status": "bun infra/scripts/production-migrations.ts status",
    "migrate:production:up": "bun infra/scripts/production-migrations.ts up",
    "migrate:dump": "bun infra/scripts/sync-production-database.ts",
    "production:wait": "bun infra/scripts/wait-for-production.ts",
    "production:release": "bun .agents/skills/production-release/scripts/release.mjs",
    "lint": "biome lint",
    "lint:fix": "biome lint --write --unsafe",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write --unsafe",
    "clean": "rm -rf node_modules .output .vercel .tanstack src/routeTree.gen.ts",
    "ci": "biome ci",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:ready": "bun run services:up && bun infra/scripts/wait-for-postgres.ts && bun run migrate:up",
    "ai:smoke": "bun infra/scripts/smoke-pi-ai.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@base-ui/react": "^1.6.0",
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@mdxeditor/editor": "^4.1.0",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "@tanstack/react-virtual": "^3.13.24",
    "@wavesurfer/react": "^1.0.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "googleapis": "^173.0.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.0",
    "nitro": "^3.0.260311-beta",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "wavesurfer.js": "^7.12.6",
    "zod": "^4.3.6",
    "zustand": "^5.0.12",
    "zustand-computed-state": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@faker-js/faker": "^10.4.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-generator": "^1.166.32",
    "@tanstack/virtual-file-routes": "^1.161.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vite": "^8.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@smithy/util-retry": "4.3.6"
  },
  "packageManager": "bun@1.3.9"
}
