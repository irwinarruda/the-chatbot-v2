{
  "name": "the-chatbot-v2",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "dev": "MODE=local vite dev",
    "dev:ngrok": "ngrok http --url=parrot-fun-nicely.ngrok-free.app --region us 3000",
    "dev:local": "concurrently -n vite,ngrok -c red,blue -k \"MODE=local bun run dev\" \"bun run dev:ngrok\"",
    "build": "vite build",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "MODE=test bun run services:ready && NODE_OPTIONS='--import tsx/esm' vitest run",
    "test:watch": "NODE_OPTIONS='--import tsx/esm' vitest",
    "test:local": "NODE_OPTIONS='--import tsx/esm' MODE=local vitest run",
    "test:prev": "NODE_OPTIONS='--import tsx/esm' MODE=preview vitest run",
    "tui": "MODE=tui vite dev",
    "cli": "cd cli && bun run dev",
    "migrate:up": "bun infra/scripts/migrate.ts up",
    "migrate:down": "bun infra/scripts/migrate.ts down",
    "migrate:create": "node-pg-migrate create --migration-file-language js --migrations-dir infra/migrations",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format",
    "format:fix": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "clean": "rm -rf node_modules .output .vercel .tanstack src/routeTree.gen.ts",
    "ci": "biome ci",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:ready": "bun run services:up && bun infra/scripts/wait-for-postgres.ts && bun run migrate:up"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "@wavesurfer/react": "^1.0.12",
    "crypto-js": "^4.2.0",
    "googleapis": "^171.4.0",
    "jose": "^6.2.2",
    "marked": "^18.0.0",
    "nitro": "^3.0.260311-beta",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@faker-js/faker": "^10.4.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.3.9"
}
