# Database
DATABASE_CONNECTION_STRING=ConnectionString
DATABASE_NAME=DatabaseName
DATABASE_SERVER_VERSION=17.7

# Encryption
ENCRYPTION_TEXT_32_BYTES=Text32Bytes
ENCRYPTION_TEXT_16_BYTES=Text16Bytes

# Google OAuth
GOOGLE_CLIENT_ID=ClientId
GOOGLE_SECRET_CLIENT_KEY=SecretClientKey
GOOGLE_REDIRECT_URI=RedirectUri
GOOGLE_LOGIN_URI=LoginUri
GOOGLE_WEB_REDIRECT_URI=
GOOGLE_SERVICE_ACCOUNT_ID=ServiceAccountId
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=ServiceAccountPrivateKey
GOOGLE_SPEECH_PROJECT_ID=SpeechProjectId
GOOGLE_SPEECH_REGION=SpeechRegion
GOOGLE_SPEECH_RECOGNIZER_ID=SpeechRecognizerId
GOOGLE_SPEECH_MODEL=SpeechModel
GOOGLE_SPEECH_LANGUAGE_CODES=pt-BR,en-US
GOOGLE_SPEECH_ENDPOINT=SpeechEndpoint
GOOGLE_APPLICATION_NAME=ApplicationName
GOOGLE_SHEETS_TEST_SHEET_ID=TestSheetId

# WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=PhoneNumberId
WHATSAPP_ACCOUNT_ID=AccountId
WHATSAPP_BUSINESS_ID=BusinessId
WHATSAPP_ACCESS_TOKEN=AccessToken
WHATSAPP_APP_NAME=AppName
WHATSAPP_VERSION=Version
WHATSAPP_WEBHOOK_VERIFY_TOKEN=WebhookVerifyToken
WHATSAPP_APP_SECRET=AppSecret

# Cloudflare R2 Storage
R2_ACCOUNT_ID=AccountId
R2_ACCESS_KEY_ID=AccessKeyId
R2_SECRET_ACCESS_KEY=SecretAccessKey
R2_BUCKET_NAME=BucketName
R2_PUBLIC_URL=PublicUrl
R2_SERVICE_URL=ServiceUrl

# AI Provider
AI_PROVIDER=openai
AI_API_KEY=ApiKey
AI_MODEL=Model

# OpenAI (for speech-to-text)
OPENAI_API_KEY=ApiKey
OPENAI_SPEECH_MODEL=SpeechModel

# Auth
AUTH_HASH_PASSWORD=HashPassword

# Summarization
SUMMARIZATION_MESSAGE_COUNT_THRESHOLD=20

# App
PORT=3000

# Web Chat Auth
JWT_SECRET=JWT_SECRET
JWT_EXPIRES_IN=7d

# Just for testing. Do not use in production.
STARTING_ALLOWED_PHONE_NUMBER=1234567890

